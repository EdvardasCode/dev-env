#!/usr/bin/env bash
set -e

log() { echo "[essentials] $*"; }

install_brew() {
    if command -v brew &>/dev/null; then
        log "brew: already installed, skipping"
        return
    fi
    log "brew: installing..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

install_brew
