#!/usr/bin/env bash
set -e

log() { echo "[essentials] $*"; }

install_brew() {
    if command -v brew &>/dev/null; then
        log "brew: already installed, skipping"
        return
    fi
    log "brew: installing..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

install_nvm() {
    if [ -d "$HOME/.nvm" ]; then
        log "nvm: already installed, skipping"
        return
    fi
    log "nvm: installing..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
}

install_node() {
    export NVM_DIR="$HOME/.nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    if ! command -v nvm &>/dev/null; then
        log "node: nvm not available, skipping"
        return
    fi
    if nvm ls --no-colors 2>/dev/null | grep -q "lts/"; then
        log "node: LTS already installed, skipping"
        return
    fi
    log "node: installing LTS..."
    nvm install --lts
}

install_goenv() {
    if command -v goenv &>/dev/null; then
        log "goenv: already installed, skipping"
        return
    fi
    log "goenv: installing..."
    brew install goenv
}

install_go() {
    export GOENV_ROOT="$HOME/.goenv"
    export PATH="$GOENV_ROOT/bin:$PATH"
    if ! command -v goenv &>/dev/null; then
        log "go: goenv not available, skipping"
        return
    fi
    eval "$(goenv init -)"

    latest=$(goenv install --list | grep -E '^\s+[0-9]+\.[0-9]+\.[0-9]+$' | tail -1 | tr -d ' ')
    if goenv versions 2>/dev/null | grep -qF "$latest"; then
        log "go: $latest already installed, skipping"
        return
    fi
    log "go: installing $latest..."
    goenv install "$latest"
    goenv global "$latest"
}

install_ghostty() {
    if [ -d "/Applications/Ghostty.app" ]; then
        log "ghostty: already installed, skipping"
        return
    fi
    log "ghostty: installing..."
    brew install --cask ghostty
}

install_arc() {
    if [ -d "/Applications/Arc.app" ]; then
        log "arc: already installed, skipping"
        return
    fi
    log "arc: installing..."
    brew install --cask arc
}

install_brew
install_nvm
install_node
install_goenv
install_go
install_ghostty
install_arc
